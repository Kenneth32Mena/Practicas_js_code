class Persona{
  constructor(nombre,edad){
    this.nombre=nombre;
    this.edad=edad;
  }
  presentarse(){
    console.log(`Soy ${this.nombre}, tengo ${this.edad} años.`);
  }
  trabajar(){
    console.log(`Estoy ocupado.`)
  }

  
}
class Estudiante extends Persona {
  constructor(nombre,edad,materiaFavorita){
    super(nombre,edad)
    this.materiaFavorita=materiaFavorita;
  }
  presentarse(){
    console.log(`Soy ${this.nombre}, tengo ${this.edad} años y mi materia favorita es ${this.materiaFavorita}`);
  }
   trabajar(){
    console.log(`Estoy estudiando.`)
  }
}
class Profesor extends Persona {
  constructor(nombre,edad,materiaQueEnseña){
  super(nombre,edad)
  
  this.materiaQueEnseña=materiaQueEnseña;
  }

  presentarse(){
     console.log(`Soy ${this.nombre}, tengo ${this.edad} años y  enseño ${this.materiaQueEnseña}`);
  }
   trabajar(){
    console.log(`Estoy enseñando.`)
  }
} 
